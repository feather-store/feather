# Include documentation
include README.md
include LICENSE
include CHANGELOG.md
include CONTRIBUTING.md

# Include D3.js for offline visualization
include feather_db/d3.min.js

# Include C++ source and headers
recursive-include include *.h
recursive-include src *.cpp
recursive-include bindings *.cpp

# Include examples (cloud/brand-tenant files excluded below)
recursive-include examples *.py *.md
exclude examples/azure_*

# Exclude build artifacts (incl. locally-compiled extensions)
global-exclude *.pyc
global-exclude *.pyo
global-exclude *.o
global-exclude *.a
global-exclude *.so
global-exclude *.dylib
global-exclude *.pyd
global-exclude __pycache__
global-exclude *.feather
global-exclude *.npy

# Exclude test files
prune p-test
prune feather-cli/target
exclude feather-cli/Cargo.lock
